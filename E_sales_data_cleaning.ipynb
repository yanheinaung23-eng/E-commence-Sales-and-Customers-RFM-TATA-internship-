   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "# 1. LOAD DATA\n",
    "\n",
    "file_path = \"C:\\Tableau Data\\Online Retail Project TATA\\Online Retail Original.xlsx\"\n,
    "df = pd.read_excel(file_path)\n",
    "\n",
    "print(\"Original Shape:\", df.shape)\n",
    "\n",
    "\n",
    "# ===============================\n",
    "# 2. REMOVE DUPLICATES\n",
    "\n",
    "df = df.drop_duplicates()\n",
    "print(\"After Removing Duplicates:\", df.shape)\n",
    "\n",
    "\n",
    "# =================================\n",
    "# 3. CLEAN DESCRIPTION COLUMN\n",
    "\n",
    "\n",
    "# Replace nulls with 'Unknown'\n",
    "df[\"Description\"] = df[\"Description\"].fillna(\"Unknown\")\n",
    "\n",
    "# Replace descriptions containing '?' with 'Unknown'\n",
    "df.loc[df[\"Description\"].str.contains(r\"\\?\", na=False), \"Description\"] = \"Unknown\"\n",
    "\n",
    "# Strip extra spaces\n",
    "df[\"Description\"] = df[\"Description\"].str.strip()\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 4. CREATE PRODUCT CATEGORY\n",
    "\n",
    "\n",
    "def categorize(desc):\n",
    "    desc = str(desc).upper()\n",
    "\n",
    "    if \"CHRISTMAS\" in desc:\n",
    "        return \"Christmas\"\n",
    "    elif any(word in desc for word in [\"MUG\", \"PLATE\", \"BOWL\", \"KITCHEN\"]):\n",
    "        return \"Kitchenware\"\n",
    "    elif any(word in desc for word in [\"LAMP\", \"CANDLE\", \"DECOR\", \"VINTAGE\"]):\n",
    "        return \"Home Decor\"\n",
    "    elif any(word in desc for word in [\"TOY\", \"DOLL\", \"GAME\"]):\n",
    "        return \"Toys & Gifts\"\n",
    "    elif any(word in desc for word in [\"CARD\", \"PAPER\", \"NOTEBOOK\"]):\n",
    "        return \"Stationery\"\n",
    "    elif desc == \"UNKNOWN\":\n",
    "        return \"Unknown\"\n",
    "    else:\n",
    "        return \"Other\"\n",
    "\n",
    "df[\"Product_Category\"] = df[\"Description\"].apply(categorize)\n",
    "\n",
    "\n",
    "# ===============================\n",
    "# 5. HANDLE RETURNS (NEGATIVE QUANTITY)\n",
    "\n",
    "\n",
    "df[\"Transaction_Type\"] = np.where(df[\"Quantity\"] < 0, \"Return\", \"Sale\")\n",
    "\n",
    "\n",
    "# ===============================\n",
    "# 6. DATA VALIDATION RULES\n",
    "\n",
    "\n",
    "# Remove invalid sales (Quantity < 1 for Sale)\n",
    "df = df[~((df[\"Transaction_Type\"] == \"Sale\") & (df[\"Quantity\"] < 1))]\n",
    "\n",
    "# Remove invalid UnitPrice (< 0)\n",
    "df = df[df[\"UnitPrice\"] >= 0]\n",
    "\n",
    "# Remove Quantity = 0\n",
    "df = df[df[\"Quantity\"] != 0]\n",
    "\n",
    "\n",
    "# ================================\n",
    "# 7. CREATE REVENUE COLUMN\n",
    "\n",
    "\n",
    "df[\"Revenue\"] = np.where(\n",
    "    df[\"Transaction_Type\"] == \"Sale\",\n",
    "    df[\"Quantity\"] * df[\"UnitPrice\"],\n",
    "    0\n",
    ")\n",
    "\n",
    "\n",
    "# ===============================\n",
    "# 8. SPLIT INVOICEDATE\n",
    "\n",
    "\n",
    "df[\"InvoiceDate\"] = pd.to_datetime(df[\"InvoiceDate\"])\n",
    "\n",
    "df[\"Invoice_Date\"] = df[\"InvoiceDate\"].dt.date\n",
    "df[\"Invoice_Time\"] = df[\"InvoiceDate\"].dt.time\n",
    "\n",
    "\n",
    "# =================================\n",
    "# 9. HANDLE CUSTOMER ID\n",
    "\n",
    "\n",
    "df[\"Customer_Type\"] = np.where(df[\"CustomerID\"].isna(),\n",
    "                               \"Guest\",\n",
    "                               \"Registered\")\n",
    "\n",
    "\n",
    "# ==================================\n",
    "# 10. CLEAN COUNTRY COLUMN\n",
    "\n",
    "\n",
    "df[\"Country\"] = df[\"Country\"].str.strip()\n",
    "\n",
    "\n",
    "# ===============================\n",
    "# 11. FINAL CHECKS\n",
    "\n",
    "\n",
    "print(\"\\nFinal Shape:\", df.shape)\n",
    "print(\"\\nMissing Values:\")\n",
    "print(df.isnull().sum())\n",
    "\n",
    "print(\"\\nData Types:\")\n",
    "print(df.dtypes)\n",
    "\n",
    "\n",
    "# ===============================\n",
    "# 12. SAVE CLEANED FILE\n",
    "\n",
    "\n",
    "df.to_csv(\"Online_Retail_Cleaned.csv\", index=False)\n",
    "df.to_excel(\"Online_Retail_Cleaned.xlsx\", index=False)\n",
    "\n"
   ]
  },
